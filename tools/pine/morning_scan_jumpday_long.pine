//@version=6
// =============================================================================
// FinDesk Jump-Day Long Rider — long-only, one morning entry on jump-list days
// -----------------------------------------------------------------------------
// v2 of the scan execution layer, and the ONLY configuration that survived a
// 19-config parameter sweep plus a 7-symbol holdout on real Alpaca SIP 5-minute
// data (Aug 2025 - Jul 2026). Every high-frequency long-scalping variant lost
// money after costs; this did not:
//   HIMS +$3,931 (PF 2.2) · QBTS +$1,820 (PF 1.45) · PLTR +$631 · OKTA +$509
//   SOFI -$682 · MARA -$654 · RIOT -$509  →  aggregate +$5,046 on $25k.
//
// The edge lives where the Morning Scan said it would: GAP-UP mornings on
// multi-trade-profile stocks. So this strategy:
//   TRADES ONLY jump-list days: scan-qualified (multi-trade profile, pre-market
//   volume, price ceiling) AND gap up >= gapUpMin at the open. Long only.
//   ENTRY: first pullback that tags the 9-EMA and closes back above it, with
//   close > session VWAP and 9-EMA > 20-EMA, between 09:40 and 11:00.
//   Default ONE trade per day — the tested config. More entries allowed via
//   input, but every tested higher-frequency variant performed worse.
//   EXIT: structural stop below the pullback low (0.8% buffer), then RIDE to
//   the 15:50 flatten. No profit target by default (rrTarget = 0): the tested
//   winner let winners run into the close. A daily loss limit halts the day.
//
// USE ON A 5-MINUTE CHART with Extended Trading Hours ON (pre-market volume
// and the session VWAP need the pre-market bars).
// Educational template validated on 2025-26 data — walk-forward before any
// capital. NOT financial advice, NOT proven profitable going forward.
// =============================================================================
strategy("FinDesk Jump-Day Long Rider", overlay = true,
     initial_capital = 25000,
     commission_type = strategy.commission.percent, commission_value = 0.02,
     slippage = 2,
     calc_on_every_tick = false,
     margin_long = 100, margin_short = 100)

// ---- Scan / day filter ----------------------------------------------------------
rangeThresh = input.float(2.0, "Multi-trade day range %", minval = 0.5, group = "Scan filter")
mtdLookback = input.int(10, "Multi-trade lookback (days)", minval = 5, maxval = 20, group = "Scan filter")
mtdMin      = input.int(7, "Min multi-trade days", minval = 1, maxval = 20, group = "Scan filter")
pmDollarMin = input.float(2000000, "Min pre-market $ volume (0 = off)", minval = 0, group = "Scan filter")
priceCeil   = input.float(150, "Price ceiling $", minval = 1, group = "Scan filter")
gapUpMin    = input.float(1.5, "Min gap up % (jump-list days only)", minval = 0.1, group = "Scan filter")

// ---- Execution --------------------------------------------------------------------
entrySess   = input.session("0940-1100", "Entry window (ET)", group = "Execution")
flatSess    = input.session("1550-1600", "Flatten window (ET)", group = "Execution")
stopBufPct  = input.float(0.8, "Stop buffer below pullback low (%)", minval = 0.1, group = "Execution")
rrTarget    = input.float(0.0, "Reward:risk target (0 = ride to close)", minval = 0, group = "Execution")
riskPct     = input.float(1.0, "Risk % of equity per trade", minval = 0.1, maxval = 5, group = "Execution")
notionalCap = input.float(50, "Max position (% of equity)", minval = 10, maxval = 100, group = "Execution")
maxTrades   = input.int(1, "Max trades per day (1 = tested config)", minval = 1, maxval = 10, group = "Execution")
dayLoss     = input.float(500, "Daily loss limit $ (halt entries)", minval = 0, group = "Execution")

// ---- Daily stats from COMPLETED sessions only (non-repainting [1] idiom) ---------
rangePctD = (high - low) / close * 100
[prevClose, mtd] =
     request.security(syminfo.tickerid, "1D",
         [close[1],
          math.sum(rangePctD >= rangeThresh ? 1 : 0, mtdLookback)[1]],
         lookahead = barmerge.lookahead_on)

// ---- Day state ---------------------------------------------------------------------
// Pre-market conviction measured in DOLLARS (research/findings.md: share
// counts don't scale across price classes) — matches the scalper strategy.
var float pmDollar = 0.0
var int tradesToday = 0
var float dayStartEq = na
if timeframe.change("1D")
    pmDollar := 0.0
    tradesToday := 0
    dayStartEq := na
if session.ispremarket
    pmDollar += nz(volume) * close

// Gap locked at the opening bell (open vs prior close), same as the scan.
var float dayGap = 0.0
if session.isfirstbar_regular
    dayGap := nz(prevClose) > 0 ? (open - prevClose) / prevClose * 100 : 0.0
    dayStartEq := strategy.equity

// ---- Qualification: jump-list day only ----------------------------------------------
qualified = mtd >= mtdMin and close <= priceCeil and (pmDollarMin == 0 or pmDollar >= pmDollarMin)
jumpDay   = dayGap >= gapUpMin
dayPnl    = na(dayStartEq) ? 0.0 : strategy.equity - dayStartEq
riskOn    = dayLoss == 0 or dayPnl > -dayLoss

// ---- Signal: first 9-EMA pullback reclaim above VWAP ---------------------------------
e9   = ta.ema(close, 9)
e20  = ta.ema(close, 20)
vw   = ta.vwap
pullbackTag = low <= e9 and close > e9
bias        = close > vw and e9 > e20

totalEntries = strategy.closedtrades + strategy.opentrades
if totalEntries > totalEntries[1]
    tradesToday += 1

inEntryWindow = not na(time(timeframe.period, entrySess))
canEnter = qualified and jumpDay and riskOn and inEntryWindow and
     strategy.position_size == 0 and tradesToday < maxTrades and session.ismarket

stopLevel = math.min(low, low[1]) - stopBufPct / 100 * close
stopDist  = close - stopLevel
riskCash  = strategy.equity * riskPct / 100
rawQty    = stopDist > 0 ? riskCash / stopDist : 0.0
capQty    = close > 0 ? strategy.equity * notionalCap / 100 / close : 0.0
qty       = math.floor(math.min(rawQty, capQty))

if canEnter and pullbackTag and bias and qty >= 1 and stopDist > 0
    strategy.entry("Long", strategy.long, qty = qty)
    // Structural stop at an absolute level (below the pullback low) — the level
    // is what matters, not the distance from fill. Optional RR target.
    if rrTarget > 0
        strategy.exit("Long exit", "Long", stop = stopLevel, limit = close + stopDist * rrTarget)
    else
        strategy.exit("Long exit", "Long", stop = stopLevel)

// ---- Hard EOD flatten (no overnight risk) ---------------------------------------------
if not na(time(timeframe.period, flatSess))
    strategy.cancel_all()
    strategy.close_all(comment = "EOD flat")

// ---- BIG buy / exit markers + live stop line (VISUAL ONLY — no effect on logic) --------
// Capture the protective stop at the signal bar so the red line shows the ACTUAL stop.
var float pendingStop = na
if canEnter and pullbackTag and bias and qty >= 1 and stopDist > 0
    pendingStop := stopLevel
justEntered = strategy.position_size > 0 and strategy.position_size[1] == 0
justExited  = strategy.position_size == 0 and strategy.position_size[1] > 0
var float activeStop = na
if justEntered
    activeStop := pendingStop
if justExited
    activeStop := na
plotshape(justEntered, "BUY", shape.labelup, location.belowbar, color.new(color.green, 0), text = "BUY", textcolor = color.white, size = size.large)
plotshape(justExited, "EXIT", shape.labeldown, location.abovebar, color.new(color.red, 0), text = "EXIT", textcolor = color.white, size = size.large)
plot(activeStop, "Protective stop", color = color.new(color.red, 0), linewidth = 2, style = plot.style_linebr)

// ---- Chart context ----------------------------------------------------------------------
plot(vw, "Session VWAP", color = color.new(color.orange, 30))
plot(e9, "EMA 9", color = color.new(color.aqua, 50))
plot(prevClose, "Prior close", color = color.new(color.yellow, 60))
bgcolor(session.ispremarket ? color.new(color.blue, 92) :
     qualified and jumpDay and session.ismarket ? color.new(color.green, 94) : na,
     title = "Pre-market / jump-day shading")
