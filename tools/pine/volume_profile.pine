//@version=6
// =============================================================================
// FinDesk Volume Profile — Cheap / Fair / Expensive (indicator, not a strategy)
// -----------------------------------------------------------------------------
// Maps WHERE the market did business: a horizontal histogram of traded volume
// by price over the current session (or a fixed lookback). It answers "is price
// cheap, fair, or expensive relative to where volume actually changed hands?" —
// the same read as a classic Volume Profile.
//
//   - POC  (Point of Control) = the single price row with the most volume. This
//     is the "FAIR" line — the market's accepted price.
//   - Value Area (default 70% of session volume around the POC) -> VAH / VAL.
//   - ABOVE the Value Area High = "EXPENSIVE" (thin volume, price extended up).
//   - BELOW the Value Area Low  = "CHEAP"     (thin volume, price extended down).
//   - Inside the Value Area     = "FAIR"      (accepted / balanced).
//
// Long-only desk read: "CHEAP re-entering value" is a constructive pullback;
// "EXPENSIVE" is where a rider is extended and chasing is dangerous. This is a
// STRUCTURAL CONTEXT overlay — it places no orders and fires no trade signal.
//
// USE ON AN INTRADAY CHART (1-15 min). Session mode profiles the regular-hours
// session and resets at each new RTH open. Research overlay only — not advice.
// =============================================================================
indicator("FinDesk Volume Profile — Cheap / Fair / Expensive", overlay = true,
     max_boxes_count = 500, max_lines_count = 20, max_labels_count = 20)

// ---- Inputs -----------------------------------------------------------------
rows      = input.int(24, "Profile rows", minval = 5, maxval = 100,
     tooltip = "Number of price buckets the volume is binned into.")
vaInput   = input.float(70, "Value area %", minval = 30, maxval = 95,
     tooltip = "Share of session volume that defines the Value Area (VAH/VAL).")
profMode  = input.string("Session", "Profile window", options = ["Session", "Lookback bars"],
     tooltip = "Session = current RTH day, resets at the open. Lookback = the last N bars.")
lookbackN = input.int(78, "Lookback bars (Lookback mode)", minval = 10, maxval = 500,
     tooltip = "Bars profiled in Lookback mode (78 ~ one RTH day on a 5m chart).")
widthPct  = input.int(35, "Profile width (% of session bars)", minval = 5, maxval = 100)
offsetBar = input.int(3, "Right offset (bars)", minval = 0, maxval = 50)
cheapCol  = input.color(color.new(#26a69a, 35), "Cheap side (below POC)")
expCol    = input.color(color.new(#ef5350, 35), "Expensive side (above POC)")
pocCol    = input.color(color.new(color.orange, 0), "POC (Fair)")
vaFill    = input.color(color.new(color.gray, 82), "Value-area shading")
showVA    = input.bool(true, "Shade value area")
showTable = input.bool(true, "Show zone table")

vaPct = vaInput / 100.0

// ---- Session bar counter (RTH), reset at each new regular session ------------
inMkt  = session.ismarket
newSes = inMkt and not nz(inMkt[1], false)
var int cnt = 0
if profMode == "Lookback bars"
    cnt := lookbackN
else
    cnt := newSes ? 1 : (inMkt ? cnt + 1 : cnt)

// ---- Profile state (computed on the last bar for the visual + live zone) -----
var float[] vol = array.new_float(rows, 0.0)
var float g_poc = na
var float g_vah = na
var float g_val = na
var float g_hi  = na
var float g_lo  = na
var int   g_pocR = 0

// ---- Drawing handles (cleared & redrawn each render) ------------------------
var box[]   boxes = array.new_box()
var line[]  lines = array.new_line()
var label[] labs  = array.new_label()

// for...in is empty-safe; `for i = 0 to size-1` on an empty array becomes
// `for 0 to -1`, which Pine runs DOWNWARD (i=0) and throws OOB on the first render.
clearDrawings() =>
    for b in boxes
        box.delete(b)
    array.clear(boxes)
    for ln in lines
        line.delete(ln)
    array.clear(lines)
    for lb in labs
        label.delete(lb)
    array.clear(labs)

if barstate.islast and cnt > 1
    // reset bins
    for r = 0 to rows - 1
        array.set(vol, r, 0.0)

    // Bound the window to bars that actually exist: on a short-history chart cnt
    // can exceed available bars, and high[i]/low[i] past history return na, which
    // poisons hi/lo and blocks the entire render. (Session mode self-bounds; this
    // matters most for Lookback mode on a freshly loaded symbol.)
    int actualCnt = math.min(cnt, bar_index + 1)

    // pass 1 — session hi/lo over the profiled window
    float hi = high
    float lo = low
    for i = 0 to actualCnt - 1
        hi := math.max(hi, high[i])
        lo := math.min(lo, low[i])

    float rng = hi - lo
    if rng > 0
        float rowSz = rng / rows

        // pass 2 — distribute each bar's volume across the rows its range spans
        for i = 0 to actualCnt - 1
            float bh = high[i]
            float bl = low[i]
            float bv = nz(volume[i])
            int r0 = int(math.floor((bl - lo) / rowSz))
            int r1 = int(math.floor((bh - lo) / rowSz))
            r0 := math.max(0, math.min(rows - 1, r0))
            r1 := math.max(0, math.min(rows - 1, r1))
            if r1 <= r0
                array.set(vol, r0, array.get(vol, r0) + bv)
            else
                float per = bv / (r1 - r0 + 1)
                for r = r0 to r1
                    array.set(vol, r, array.get(vol, r) + per)

        // POC + total
        int   pocR = 0
        float pocV = 0.0
        float total = 0.0
        for r = 0 to rows - 1
            float v = array.get(vol, r)
            total += v
            if v > pocV
                pocV := v
                pocR := r

        // value area — grow out from the POC toward the heavier neighbour
        float acc = array.get(vol, pocR)
        int loR = pocR
        int hiR = pocR
        while acc < total * vaPct and (loR > 0 or hiR < rows - 1)
            float below = loR > 0 ? array.get(vol, loR - 1) : -1.0
            float above = hiR < rows - 1 ? array.get(vol, hiR + 1) : -1.0
            if above >= below
                hiR += 1
                acc += array.get(vol, hiR)
            else
                loR -= 1
                acc += array.get(vol, loR)

        // stash levels for zone logic / table / alerts
        g_pocR := pocR
        g_poc  := lo + (pocR + 0.5) * rowSz
        g_vah  := lo + (hiR + 1) * rowSz
        g_val  := lo + loR * rowSz
        g_hi   := hi
        g_lo   := lo

        // ---- draw ----------------------------------------------------------
        clearDrawings()
        int profBars = math.max(8, int(actualCnt * widthPct / 100.0))
        int xLeft = bar_index + offsetBar
        for r = 0 to rows - 1
            float v = array.get(vol, r)
            if v > 0
                int w = int(profBars * v / pocV)
                float yTop = lo + (r + 1) * rowSz
                float yBot = lo + r * rowSz
                color c = r == pocR ? color.new(pocCol, 45) : r > pocR ? expCol : cheapCol
                array.push(boxes, box.new(xLeft, yTop, xLeft + math.max(1, w), yBot,
                     border_width = 0, bgcolor = c))

        // value-area shading behind the profile
        if showVA
            array.push(boxes, box.new(bar_index - actualCnt + 1, g_vah, xLeft, g_val,
                 border_color = color.new(color.gray, 60), border_width = 1,
                 bgcolor = vaFill))

        // POC / VAH / VAL rays + labels
        int xEnd = xLeft + profBars + 2
        l_poc = line.new(bar_index - actualCnt + 1, g_poc, xEnd, g_poc, color = pocCol,
             width = 2, extend = extend.none)
        l_vah = line.new(bar_index - actualCnt + 1, g_vah, xEnd, g_vah,
             color = color.new(color.gray, 20), style = line.style_dashed)
        l_val = line.new(bar_index - actualCnt + 1, g_val, xEnd, g_val,
             color = color.new(color.gray, 20), style = line.style_dashed)
        array.push(lines, l_poc)
        array.push(lines, l_vah)
        array.push(lines, l_val)
        array.push(labs, label.new(xEnd, g_vah, "Expensive ▲", style = label.style_label_left,
             color = color.new(expCol, 60), textcolor = color.white, size = size.small))
        array.push(labs, label.new(xEnd, g_poc, "Fair · POC", style = label.style_label_left,
             color = color.new(pocCol, 40), textcolor = color.white, size = size.small))
        array.push(labs, label.new(xEnd, g_val, "Cheap ▼", style = label.style_label_left,
             color = color.new(cheapCol, 40), textcolor = color.white, size = size.small))

// ---- Current-price zone (live, from the last computed profile) --------------
zone = na(g_vah) ? "—" : close > g_vah ? "EXPENSIVE" : close < g_val ? "CHEAP" : "FAIR"
zoneCol = zone == "EXPENSIVE" ? color.new(#ef5350, 0) : zone == "CHEAP" ? color.new(#26a69a, 0) : zone == "FAIR" ? color.new(color.orange, 0) : color.gray

// ---- Zone table (top-right) --------------------------------------------------
var table t = table.new(position.top_right, 2, 5, border_width = 1,
     border_color = color.new(color.gray, 70), bgcolor = color.new(color.black, 20))
f(v) => na(v) ? "N/A" : str.tostring(v, format.mintick)
if showTable and barstate.islast
    table.cell(t, 0, 0, "Volume Profile", text_color = color.new(color.aqua, 0), text_size = size.small)
    table.cell(t, 1, 0, profMode == "Session" ? "session" : str.tostring(cnt) + " bars", text_color = color.gray, text_size = size.small)
    table.cell(t, 0, 1, "Price zone", text_color = color.gray, text_size = size.small)
    table.cell(t, 1, 1, zone, text_color = zoneCol, text_size = size.normal)
    table.cell(t, 0, 2, "VAH (Expensive >)", text_color = color.gray, text_size = size.small)
    table.cell(t, 1, 2, f(g_vah), text_color = color.white, text_size = size.small)
    table.cell(t, 0, 3, "POC (Fair)", text_color = color.gray, text_size = size.small)
    table.cell(t, 1, 3, f(g_poc), text_color = color.new(color.orange, 0), text_size = size.small)
    table.cell(t, 0, 4, "VAL (Cheap <)", text_color = color.gray, text_size = size.small)
    table.cell(t, 1, 4, f(g_val), text_color = color.white, text_size = size.small)

// ---- Alerts (notify only — never place orders) ------------------------------
// Fire on the bar where price transitions between zones. The profile levels are
// recomputed on every realtime tick, so alerts are gated to bar close
// (barstate.isconfirmed) — one shot per closed bar against the settled level,
// not a flickering intrabar cross.
enterCheap = barstate.isconfirmed and not na(g_val) and close < g_val and not (close[1] < g_val)
backToFair = barstate.isconfirmed and not na(g_val) and not na(g_vah) and close >= g_val and close <= g_vah and (close[1] < g_val or close[1] > g_vah)
enterExp   = barstate.isconfirmed and not na(g_vah) and close > g_vah and not (close[1] > g_vah)

alertcondition(enterCheap, "VP: price entered CHEAP (below Value Area)",
     "Price dropped below VAL — CHEAP relative to session value")
alertcondition(backToFair, "VP: price reclaimed FAIR (Value Area)",
     "Price re-entered the Value Area — accepted/FAIR again (long-only: constructive pullback-reclaim)")
alertcondition(enterExp, "VP: price extended EXPENSIVE (above Value Area)",
     "Price pushed above VAH — EXPENSIVE / extended, chasing risk")
