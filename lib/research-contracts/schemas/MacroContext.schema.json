{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "contract": {
      "type": "string",
      "const": "MacroContext"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "macroContextId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "required": {
      "type": "boolean"
    },
    "triggerReasonCodes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "activeEvents": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "eventType": {
            "type": "string"
          },
          "scheduledTime": {
            "anyOf": [
              {
                "type": "string",
                "format": "date-time",
                "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-]\\d{2}:\\d{2})))$"
              },
              {
                "type": "null"
              }
            ]
          },
          "reportedValue": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ]
          },
          "consensusValue": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ]
          },
          "unit": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          },
          "revisionStatus": {
            "type": "string",
            "enum": [
              "PRELIMINARY",
              "REVISED",
              "FINAL",
              "UNKNOWN"
            ]
          },
          "sourceDocumentId": {
            "anyOf": [
              {
                "type": "string",
                "minLength": 1,
                "maxLength": 120
              },
              {
                "type": "null"
              }
            ]
          }
        },
        "required": [
          "eventType",
          "scheduledTime",
          "reportedValue",
          "consensusValue",
          "unit",
          "revisionStatus",
          "sourceDocumentId"
        ],
        "additionalProperties": false
      }
    },
    "tickerSensitivity": {
      "type": "string",
      "enum": [
        "LIKELY",
        "POSSIBLE",
        "UNLIKELY",
        "UNKNOWN"
      ]
    },
    "causalConfidence": {
      "type": "string",
      "enum": [
        "HIGH",
        "MEDIUM",
        "LOW",
        "UNKNOWN"
      ]
    },
    "unknownFields": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string"
          },
          "reasonCode": {
            "type": "string"
          },
          "attemptedSourceIds": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1,
              "maxLength": 120
            }
          },
          "blocking": {
            "type": "boolean"
          }
        },
        "required": [
          "path",
          "reasonCode",
          "attemptedSourceIds",
          "blocking"
        ],
        "additionalProperties": false
      }
    },
    "asOf": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-]\\d{2}:\\d{2})))$"
    }
  },
  "required": [
    "contract",
    "version",
    "macroContextId",
    "required",
    "triggerReasonCodes",
    "activeEvents",
    "tickerSensitivity",
    "causalConfidence",
    "unknownFields",
    "asOf"
  ],
  "additionalProperties": false
}
