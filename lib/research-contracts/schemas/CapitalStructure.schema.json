{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "contract": {
      "type": "string",
      "const": "CapitalStructure"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "diligenceId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "symbol": {
      "type": "string",
      "pattern": "^[A-Z0-9.\\-=^]{1,12}$"
    },
    "lifecycleType": {
      "type": "string",
      "enum": [
        "RECENT_IPO",
        "DIRECT_LISTING",
        "SPAC",
        "DE_SPAC",
        "FOLLOW_ON_OFFERING",
        "ATM_PROGRAM",
        "ACTIVE_SHELF",
        "LOCKUP_EVENT",
        "MATURE",
        "UNKNOWN"
      ]
    },
    "filings": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "form": {
            "type": "string"
          },
          "accessionNumber": {
            "type": "string"
          },
          "acceptedAt": {
            "anyOf": [
              {
                "type": "string",
                "format": "date-time",
                "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-]\\d{2}:\\d{2})))$"
              },
              {
                "type": "null"
              }
            ]
          },
          "sourceDocumentId": {
            "type": "string",
            "minLength": 1,
            "maxLength": 120
          }
        },
        "required": [
          "form",
          "accessionNumber",
          "acceptedAt",
          "sourceDocumentId"
        ],
        "additionalProperties": false
      }
    },
    "sharesOutstanding": {
      "type": "object",
      "properties": {
        "value": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "CONFIRMED",
            "ESTIMATED",
            "UNKNOWN",
            "NOT_APPLICABLE"
          ]
        },
        "method": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "claimId": {
          "anyOf": [
            {
              "type": "string",
              "minLength": 1,
              "maxLength": 120
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "value",
        "status",
        "method",
        "claimId"
      ],
      "additionalProperties": false
    },
    "estimatedTradableFloat": {
      "type": "object",
      "properties": {
        "value": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "CONFIRMED",
            "ESTIMATED",
            "UNKNOWN",
            "NOT_APPLICABLE"
          ]
        },
        "method": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "claimId": {
          "anyOf": [
            {
              "type": "string",
              "minLength": 1,
              "maxLength": 120
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "value",
        "status",
        "method",
        "claimId"
      ],
      "additionalProperties": false
    },
    "offeringPrice": {
      "type": "object",
      "properties": {
        "value": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "CONFIRMED",
            "ESTIMATED",
            "UNKNOWN",
            "NOT_APPLICABLE"
          ]
        },
        "method": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "claimId": {
          "anyOf": [
            {
              "type": "string",
              "minLength": 1,
              "maxLength": 120
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "value",
        "status",
        "method",
        "claimId"
      ],
      "additionalProperties": false
    },
    "lockupTerms": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "description": {
            "type": "string"
          },
          "expiresAt": {
            "anyOf": [
              {
                "type": "string",
                "format": "date-time",
                "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-]\\d{2}:\\d{2})))$"
              },
              {
                "type": "null"
              }
            ]
          },
          "claimId": {
            "anyOf": [
              {
                "type": "string",
                "minLength": 1,
                "maxLength": 120
              },
              {
                "type": "null"
              }
            ]
          }
        },
        "required": [
          "description",
          "expiresAt",
          "claimId"
        ],
        "additionalProperties": false
      }
    },
    "warrantsAndConvertibles": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "description": {
            "type": "string"
          },
          "claimId": {
            "anyOf": [
              {
                "type": "string",
                "minLength": 1,
                "maxLength": 120
              },
              {
                "type": "null"
              }
            ]
          }
        },
        "required": [
          "description",
          "claimId"
        ],
        "additionalProperties": false
      }
    },
    "dilutionEvents": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "description": {
            "type": "string"
          },
          "eventTime": {
            "anyOf": [
              {
                "type": "string",
                "format": "date-time",
                "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-]\\d{2}:\\d{2})))$"
              },
              {
                "type": "null"
              }
            ]
          },
          "claimId": {
            "anyOf": [
              {
                "type": "string",
                "minLength": 1,
                "maxLength": 120
              },
              {
                "type": "null"
              }
            ]
          }
        },
        "required": [
          "description",
          "eventTime",
          "claimId"
        ],
        "additionalProperties": false
      }
    },
    "unknownFields": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string"
          },
          "reasonCode": {
            "type": "string"
          },
          "attemptedSourceIds": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1,
              "maxLength": 120
            }
          },
          "blocking": {
            "type": "boolean"
          }
        },
        "required": [
          "path",
          "reasonCode",
          "attemptedSourceIds",
          "blocking"
        ],
        "additionalProperties": false
      }
    },
    "asOf": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-]\\d{2}:\\d{2})))$"
    }
  },
  "required": [
    "contract",
    "version",
    "diligenceId",
    "symbol",
    "lifecycleType",
    "filings",
    "sharesOutstanding",
    "estimatedTradableFloat",
    "offeringPrice",
    "lockupTerms",
    "warrantsAndConvertibles",
    "dilutionEvents",
    "unknownFields",
    "asOf"
  ],
  "additionalProperties": false
}
