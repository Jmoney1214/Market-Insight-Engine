{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "contract": {
      "type": "string",
      "const": "SentimentReading"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "readingId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "symbol": {
      "type": "string",
      "pattern": "^[A-Z0-9.\\-=^]{1,12}$"
    },
    "band": {
      "type": "string",
      "enum": [
        "STRONG_BEARISH",
        "BEARISH",
        "NEUTRAL",
        "BULLISH",
        "STRONG_BULLISH"
      ]
    },
    "score": {
      "type": "number",
      "minimum": -1,
      "maximum": 1
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "kind": {
            "type": "string",
            "enum": [
              "NEWS",
              "REDDIT",
              "X",
              "OTHER_SOCIAL"
            ]
          },
          "itemCount": {
            "type": "integer",
            "minimum": 0,
            "maximum": 9007199254740991
          }
        },
        "required": [
          "kind",
          "itemCount"
        ],
        "additionalProperties": false
      }
    },
    "evidenceIds": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 120
      }
    },
    "isEventProof": {
      "type": "boolean",
      "const": false
    },
    "asOf": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-]\\d{2}:\\d{2})))$"
    }
  },
  "required": [
    "contract",
    "version",
    "readingId",
    "symbol",
    "band",
    "score",
    "confidence",
    "sources",
    "evidenceIds",
    "isEventProof",
    "asOf"
  ],
  "additionalProperties": false
}
