# Market-Insight-Engine — environment contract.
# Copy to `.env` and fill in. The server loads repo-root `.env` at boot.
# NEVER commit a real `.env` (it is gitignored). Values here are placeholders.

# ── Runtime ──────────────────────────────────────────────────────────────────
# Node 24 is required (pinned in package.json "engines" / .nvmrc). Use: nvm use
PORT=8080

# ── Database (required) ──────────────────────────────────────────────────────
# Managed cloud Postgres (Supabase). Local dev and prod share this instance
# unless you use a Supabase branch. Drizzle connects + `drizzle-kit push` here.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require

# ── Market data (required for the live scan / copilot) ───────────────────────
# The scan short-circuits unless BOTH Alpaca and FMP are configured.
ALPACA_API_KEY_ID=
ALPACA_API_SECRET_KEY=
ALPACA_FEED=sip            # sip (paid, default) | iex
# Trading-API host for the /v2/assets universe list (defaults to the paper host).
# Set to https://api.alpaca.markets only if ALPACA_API_KEY_ID is a LIVE key.
ALPACA_TRADING_BASE=https://paper-api.alpaca.markets
FMP_API_KEY=

# ── SEC EDGAR (required for research filings) ────────────────────────────────
# Mandatory declared User-Agent per SEC fair-access; no UA → no filings evidence.
SEC_USER_AGENT=Your Name your-email@example.com

# ── LLM backbones (optional — unset ⇒ fully deterministic) ───────────────────
# A provider is "configured" only when BOTH _BASE_URL and _API_KEY are set.
# Two independent providers give genuine cross-provider judging.
AI_INTEGRATIONS_OPENAI_BASE_URL=
AI_INTEGRATIONS_OPENAI_API_KEY=
AI_INTEGRATIONS_ANTHROPIC_BASE_URL=
AI_INTEGRATIONS_ANTHROPIC_API_KEY=
AI_INTEGRATIONS_GEMINI_BASE_URL=
AI_INTEGRATIONS_GEMINI_API_KEY=
COPILOT_LLM_PROVIDER=      # optional: force one of openai|anthropic|gemini

# ── Social adapters (optional; built but not wired into the runner) ──────────
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=
X_BEARER_TOKEN=

# ── Agent auth (optional; enforcement OFF by default) ────────────────────────
REQUIRE_AGENT_TOKEN=false                  # true ⇒ reject anonymous requests 401
AGENT_TOKENS=                              # e.g. desk-claude:tok_abc,ci:tok_def

# ── MCP gateway (read-only desk proxy) ───────────────────────────────────────
MIE_API_BASE=http://127.0.0.1:8080
MIE_API_TOKEN=                             # optional bearer pass-through

# ── Experiment / offline flags (optional) ────────────────────────────────────
ALLOW_DELAYED_YAHOO=false                  # true ⇒ allow source=yahoo_delayed
COMMITTEE_PLANNER=                         # "on" ⇒ enable the opt-in lens planner
SCAN_AS_OF=                                # ISO date ⇒ point-in-time replay mode

# ── Wave 0 containment flags (fail-closed by default; exact "true" to opt in) ──
ENABLE_SEMANTIC_PROMOTION=                 # true ⇒ thaw EPISODIC→SEMANTIC promotion
ENABLE_DECISION_MEMORY=                    # true ⇒ inject decision memory into the committee
